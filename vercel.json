{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/betpredict/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "buildCommand": "cd artifacts/betpredict && corepack pnpm install --ignore-scripts && corepack pnpm build"
}
