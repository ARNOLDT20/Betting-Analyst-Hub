{
  "version": 2,
  "buildCommand": "corepack pnpm --dir artifacts/betpredict install --ignore-scripts && corepack pnpm --dir artifacts/betpredict build",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(favicon\\.svg|opengraph\\.jpg)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
